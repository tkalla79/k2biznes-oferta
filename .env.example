# =============================================================================
# K2Biznes Oferta — env vars (BACKEND_SPEC.md v1.1, sekcja 13)
# =============================================================================
# Skopiuj do .env.local (lokalnie) lub ustaw w Vercel/Supabase secrets.
# .env.local jest w .gitignore — NIGDY nie commituj kluczy.
# =============================================================================

# --- Supabase (lokalny `supabase start` wypełnia poniżej automatycznie) ------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
IP_HASH_SALT=                          # 32 bajty hex; w prod rotowany co 90 dni (sekcja 11.7)
PDF_BYPASS_SECRET=                     # 32 bajty hex; HMAC dla Edge → render auth (9.1.1)

# --- Rate limit (Upstash Redis; opcjonalne lokalnie — bez tego no-op) -------
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_TOKEN=

# --- PDF generation (sekcja 9) ----------------------------------------------
# DEV: ścieżka do binarki Chrome'a (puppeteer-core nie pobiera Chromium).
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux:   /usr/bin/google-chrome  lub  /usr/bin/chromium
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Bez tej zmiennej GET /api/public/offers/:token/pdf zwraca 503 NOT_CONFIGURED.
LOCAL_CHROME_PATH=
# PROD: zainstaluj `@sparticuz/chromium` w apps/web jako optional dep.
# (deploy step — niepotrzebne lokalnie)

# --- Email (Resend; sekcja 8) -----------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="K2Biznes <oferty@k2biznes.pl>"
EMAIL_REPLY_TO="kontakt@k2biznes.pl"

# --- AI matching (opcjonalne; sekcja 5.3 + Appendix B) ----------------------
ANTHROPIC_API_KEY=

# --- CRM (opcjonalne; sekcja 10) --------------------------------------------
HUBSPOT_ACCESS_TOKEN=
PIPEDRIVE_API_TOKEN=

# --- Monitoring (sekcja 12.1) -----------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Bootstrap super admina (sekcja 3.4 / seed.sql krok 8) ------------------
SUPER_ADMIN_EMAIL=tomasz.kalla@k2biznes.pl
