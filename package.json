{
  "name": "k2biznes-oferta",
  "private": true,
  "version": "0.1.0",
  "description": "K2Biznes Oferta — SaaS do ofert handlowych dla klientów dotacyjnych",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w apps/web run dev",
    "build": "npm -w apps/web run build",
    "lint": "npm -w apps/web run lint",
    "typecheck": "npm -w apps/web run typecheck",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:types": "supabase gen types typescript --local 2>/dev/null | sed -n '/^export /,$p' > packages/database/types.ts",
    "db:lint": "supabase db lint",
    "test": "npm -w apps/web run test"
  },
  "devDependencies": {
    "supabase": "^2.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
